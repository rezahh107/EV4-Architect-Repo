{
  "$id": "ev4-architect-stage-validation-receipt@1.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "valid"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "diagnostics": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "properties": {
    "artifact_id": {
      "minLength": 1,
      "type": "string"
    },
    "artifact_schema": {
      "const": "ev4-architect-pipeline-stage-artifact@1.1.0"
    },
    "artifact_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "diagnostics": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string"
          },
          "expected": {
            "type": "string"
          },
          "observed": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "repair_target_stage": {
            "type": [
              "string",
              "null"
            ]
          },
          "rule_id": {
            "pattern": "^ASB-R[0-9]{2}$",
            "type": "string"
          },
          "stage_id": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "rule_id",
          "stage_id",
          "path",
          "expected",
          "observed"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "receipt_id": {
      "minLength": 1,
      "type": "string"
    },
    "receipt_schema": {
      "const": "ev4-architect-stage-validation-receipt@1.1.0"
    },
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "stage_id": {
      "enum": [
        "/decompose",
        "/architectures",
        "/score-evidence",
        "/score-audit"
      ]
    },
    "status": {
      "enum": [
        "valid",
        "invalid",
        "insufficient_evidence"
      ]
    },
    "validator_id": {
      "const": "architect-pipeline-stage-boundary-validator"
    },
    "validator_version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "receipt_schema",
    "receipt_id",
    "run_id",
    "validator_id",
    "validator_version",
    "artifact_id",
    "artifact_schema",
    "artifact_sha256",
    "stage_id",
    "status",
    "diagnostics"
  ],
  "type": "object"
}
