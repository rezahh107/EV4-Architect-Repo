{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/EV4-Architect-Repo/schemas/ev4-architect-builder-feed-export.schema.json",
  "title": "EV4 Architect Builder Feed Export",
  "description": "Architect-owned non-executable handoff package for CE intake. This is not the Builder runtime intake contract.",
  "type": "object",
  "required": [
    "schema",
    "source_stage",
    "source_handoff_stage",
    "packet_purpose",
    "intended_consumer",
    "ce_review_required",
    "requires_constructability_engineer_review",
    "builder_executable_allowed",
    "builder_ready_status",
    "package_status",
    "selected_candidate_id",
    "selected_candidate_locked",
    "production_ready_allowed",
    "source_payload_ledger",
    "approved_structure_tree",
    "class_creation_application_map",
    "widget_mapping_table",
    "responsive_qa_seed",
    "forbidden_work"
  ],
  "properties": {
    "schema": { "const": "ev4-architect-builder-feed-export@1.0.0" },
    "source_stage": { "const": "/builder-feed-export" },
    "source_handoff_stage": { "const": "/handoff-export" },
    "packet_purpose": { "enum": ["ce_intake_source", "architect_handoff"] },
    "intended_consumer": { "const": "constructability_engineer" },
    "ce_review_required": { "const": true },
    "requires_constructability_engineer_review": { "const": true },
    "builder_executable_allowed": { "const": false },
    "builder_ready_status": { "const": "not_builder_ready_without_ce_proof" },
    "package_status": { "enum": ["ready", "ready_with_visible_flags", "blocked"] },
    "selected_candidate_id": { "type": "string", "minLength": 1 },
    "selected_candidate_locked": { "const": true },
    "production_ready_allowed": { "const": false },
    "source_payload_ledger": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "reference_role": { "enum": ["inspiration_only", "visual_direction", "candidate_source_evidence"] },
    "desired_outcome": { "type": "string" },
    "high_level_design_intent": { "type": "string" },
    "experience_intent": { "type": "object", "additionalProperties": true },
    "source_visual_evidence_registration": { "type": "object", "additionalProperties": true },
    "reference_screenshot_instruction": { "type": "object", "additionalProperties": true },
    "approved_structure_tree": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "class_creation_application_map": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "widget_mapping_table": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "editable_content_map": { "type": "array", "items": { "type": "object" } },
    "decoration_only_map": { "type": "array", "items": { "type": "object" } },
    "asset_replacement_map": { "type": "array", "items": { "type": "object" } },
    "scoped_css_need_map": { "type": "array", "items": { "type": "object" } },
    "responsive_qa_seed": { "type": "object", "required": ["unresolved_breakpoints", "connector_behavior_status", "meaningful_content_visibility_rule"] },
    "audit_flags_to_preserve": { "type": "array", "items": { "type": "string" } },
    "unknowns_to_preserve": { "type": "array", "items": { "type": "string" } },
    "forbidden_work": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "first_suggested_builder_batch": { "type": "object", "additionalProperties": true },
    "confirmation_request_seed": { "type": "object", "additionalProperties": true },
    "compatibility_note": { "type": "string" }
  },
  "additionalProperties": false
}
