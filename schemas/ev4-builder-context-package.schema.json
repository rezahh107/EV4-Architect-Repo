{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/elementor-v4-architect-prompt-pack/schemas/ev4-builder-context-package.schema.json",
  "title": "EV4 Builder Context Package",
  "description": "Schema stub for the Stage 11 /builder-feed-export package used by a separate interactive Elementor Builder Assistant chat.",
  "type": "object",
  "required": [
    "schema",
    "source_stage",
    "source_handoff_stage",
    "package_status",
    "selected_candidate_id",
    "selected_candidate_locked",
    "production_ready_allowed",
    "source_payload_ledger",
    "approved_structure_tree",
    "class_creation_application_map",
    "forbidden_work",
    "first_builder_batch",
    "confirmation_sentence",
    "builder_assistant_prompt_seed"
  ],
  "properties": {
    "schema": {
      "const": "ev4-builder-context-package@1.0.0"
    },
    "source_stage": {
      "const": "/builder-feed-export"
    },
    "source_handoff_stage": {
      "const": "/handoff-export"
    },
    "package_status": {
      "enum": ["ready", "ready_with_visible_flags", "blocked"]
    },
    "selected_candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_candidate_locked": {
      "const": true
    },
    "production_ready_allowed": {
      "const": false
    },
    "source_payload_ledger": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["payload_name", "schema", "status"],
        "properties": {
          "payload_name": { "type": "string" },
          "schema": { "type": "string" },
          "status": { "type": "string" },
          "source_ref": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "reference_screenshot_instruction": {
      "type": "object",
      "properties": {
        "required_in_new_chat": { "type": "boolean" },
        "allowed_use": { "type": "string" },
        "forbidden_use": { "type": "string" }
      },
      "additionalProperties": false
    },
    "approved_structure_tree": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["structure_label", "element_type", "role"],
        "properties": {
          "node_id": { "type": "string" },
          "structure_label": { "type": "string" },
          "class_name": { "type": ["string", "null"] },
          "element_type": { "type": "string" },
          "role": { "type": "string" },
          "children": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "class_creation_application_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["class_name", "related_structure_label", "elementor_node_or_element", "when_to_create", "purpose", "css_needed_now"],
        "properties": {
          "class_name": { "type": "string", "minLength": 1 },
          "related_structure_label": { "type": "string" },
          "elementor_node_or_element": { "type": "string" },
          "when_to_create": { "type": "string" },
          "reusable_or_one_off": { "enum": ["reusable", "one_off", "section_scoped", "unknown"] },
          "purpose": { "type": "string" },
          "css_needed_now": { "enum": ["yes", "no", "later", "unknown"] },
          "notes_or_unknowns": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "widget_mapping_table": {
      "type": "array",
      "items": { "type": "object" }
    },
    "editable_content_map": {
      "type": "array",
      "items": { "type": "object" }
    },
    "decoration_only_map": {
      "type": "array",
      "items": { "type": "object" }
    },
    "asset_replacement_map": {
      "type": "array",
      "items": { "type": "object" }
    },
    "scoped_css_need_map": {
      "type": "array",
      "items": { "type": "object" }
    },
    "responsive_qa_seed": {
      "type": "object"
    },
    "audit_flags_to_preserve": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unknowns_to_preserve": {
      "type": "array",
      "items": { "type": "string" }
    },
    "forbidden_work": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "first_builder_batch": {
      "type": "object",
      "required": ["max_actions", "actions"],
      "properties": {
        "max_actions": { "type": "integer", "minimum": 1, "maximum": 6 },
        "actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "type": "object",
            "required": ["action_id", "target_element", "instruction", "expected_result"],
            "properties": {
              "action_id": { "type": "string" },
              "target_element": { "type": "string" },
              "parent": { "type": "string" },
              "element_type": { "type": "string" },
              "structure_panel_name": { "type": "string" },
              "active_class": { "type": "string" },
              "instruction": { "type": "string" },
              "properties_not_to_change": { "type": "array", "items": { "type": "string" } },
              "expected_result": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "confirmation_sentence": {
      "type": "string",
      "minLength": 1
    },
    "builder_assistant_prompt_seed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
