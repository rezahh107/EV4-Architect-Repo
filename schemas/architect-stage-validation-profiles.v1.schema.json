{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ev4-architect-stage-validation-profiles@1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_schema",
    "registry_id",
    "registry_version",
    "owner_repository",
    "authorization_role",
    "profiles"
  ],
  "properties": {
    "registry_schema": {"const": "ev4-architect-stage-validation-profiles@1.0.0"},
    "registry_id": {"const": "ev4-architect-stage-validation-profiles"},
    "registry_version": {"const": "1.0.0"},
    "owner_repository": {"const": "rezahh107/EV4-Architect-Repo"},
    "authorization_role": {"const": "validation_capability_only"},
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/profile"}
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "grounding", "artifact", "validation", "receipt", "bundle", "repair"],
      "properties": {
        "stage_id": {"type": "string", "pattern": "^/[a-z0-9-]+$"},
        "grounding": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "authoritative_sources", "unresolved_semantic_decisions"],
          "properties": {
            "status": {
              "enum": [
                "explicit_active_contract",
                "deterministically_derivable_from_active_contracts",
                "proposed_model_inference",
                "conflicting_active_contracts"
              ]
            },
            "authoritative_sources": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            },
            "unresolved_semantic_decisions": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            }
          }
        },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["identity", "version", "schema_id", "schema_path"],
          "properties": {
            "identity": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "schema_id": {"type": "string", "minLength": 1},
            "schema_path": {"type": "string", "minLength": 1}
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "semantic_handler",
            "structural_validation",
            "semantic_validation",
            "executable",
            "authorization_capable"
          ],
          "properties": {
            "status": {
              "enum": [
                "full_transaction_implemented",
                "contract_defined_not_implemented",
                "blocked_missing_semantics",
                "blocked_contract_conflict",
                "terminal"
              ]
            },
            "semantic_handler": {"type": "string", "minLength": 1},
            "structural_validation": {"type": "string", "minLength": 1},
            "semantic_validation": {"type": "string", "minLength": 1},
            "executable": {"type": "boolean"},
            "authorization_capable": {"type": "boolean"}
          }
        },
        "receipt": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supported", "schema_id", "generator"],
          "properties": {
            "supported": {"type": "boolean"},
            "schema_id": {"type": "string", "minLength": 1},
            "generator": {"type": "string", "minLength": 1}
          }
        },
        "bundle": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supported", "independent_regeneration"],
          "properties": {
            "supported": {"type": "boolean"},
            "independent_regeneration": {"type": "boolean"}
          }
        },
        "repair": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ownership_status", "earliest_repair_owner", "caller_selectable"],
          "properties": {
            "ownership_status": {"enum": ["deterministic", "unresolved", "not_applicable"]},
            "earliest_repair_owner": {"type": "string", "minLength": 1},
            "caller_selectable": {"const": false}
          }
        }
      }
    }
  }
}
