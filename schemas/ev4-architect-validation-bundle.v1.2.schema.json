{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ev4-architect-validation-bundle@1.2.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_schema",
    "bundle_id",
    "run_id",
    "validator_id",
    "validator_version",
    "determinism_profile",
    "stage_sequence",
    "overall_status",
    "bundle_integrity_status",
    "run_validation_status",
    "authorization_valid",
    "authorized_next_stage",
    "repair_target_stage",
    "failure_event_path",
    "failure_event_sha256",
    "artifacts",
    "receipts",
    "boundaries",
    "anchors",
    "bundle_content_digest"
  ],
  "properties": {
    "bundle_schema": {"const": "ev4-architect-validation-bundle@1.2.0"},
    "bundle_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "validator_id": {"const": "architect-pipeline-stage-boundary-validator"},
    "validator_version": {"const": "1.2.0"},
    "determinism_profile": {"const": "deterministic_no_timestamps_v2"},
    "stage_sequence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/stage"}},
    "overall_status": {"enum": ["valid", "invalid"]},
    "bundle_integrity_status": {"const": "valid"},
    "run_validation_status": {"enum": ["valid", "invalid", "insufficient_evidence"]},
    "authorization_valid": {"type": "boolean"},
    "authorized_next_stage": {"oneOf": [{"$ref": "#/$defs/stage"}, {"type": "null"}]},
    "repair_target_stage": {"oneOf": [{"$ref": "#/$defs/stage"}, {"type": "null"}]},
    "failure_event_path": {"type": ["string", "null"]},
    "failure_event_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file_entry"}},
    "receipts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file_entry"}},
    "boundaries": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file_entry"}},
    "anchors": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file_entry"}},
    "bundle_content_digest": {"$ref": "#/$defs/sha256"}
  },
  "allOf": [
    {
      "if": {"properties": {"overall_status": {"const": "valid"}}, "required": ["overall_status"]},
      "then": {
        "properties": {
          "run_validation_status": {"const": "valid"},
          "authorization_valid": {"const": true},
          "authorized_next_stage": {"$ref": "#/$defs/stage"},
          "repair_target_stage": {"type": "null"},
          "failure_event_path": {"type": "null"},
          "failure_event_sha256": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"overall_status": {"const": "invalid"}}, "required": ["overall_status"]},
      "then": {
        "properties": {
          "run_validation_status": {"const": "invalid"},
          "authorization_valid": {"const": false},
          "authorized_next_stage": {"type": "null"},
          "repair_target_stage": {"$ref": "#/$defs/stage"},
          "failure_event_path": {"const": "failure-event.json"},
          "failure_event_sha256": {"$ref": "#/$defs/sha256"},
          "boundaries": {"minItems": 1, "maxItems": 1},
          "anchors": {"minItems": 1, "maxItems": 1}
        }
      }
    }
  ],
  "$defs": {
    "stage": {"type": "string", "pattern": "^/[a-z0-9-]+$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "file_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "id", "schema"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "id": {"type": "string", "minLength": 1},
        "schema": {"type": "string", "minLength": 1}
      }
    }
  }
}
