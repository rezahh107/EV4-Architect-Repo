{
  "$id": "ev4-stage-anchor@1.2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "anchor_type": {
            "const": "NEXT_STAGE_ANCHOR"
          }
        },
        "required": [
          "anchor_type"
        ]
      },
      "then": {
        "properties": {
          "repair_target_stage": {
            "type": "null"
          },
          "target_stage": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "anchor_type": {
            "const": "REPAIR_ANCHOR"
          }
        },
        "required": [
          "anchor_type"
        ]
      },
      "then": {
        "properties": {
          "repair_target_stage": {
            "type": "string"
          },
          "target_stage": {
            "type": "null"
          }
        }
      }
    }
  ],
  "properties": {
    "anchor_id": {
      "minLength": 1,
      "type": "string"
    },
    "anchor_schema": {
      "const": "ev4-stage-anchor@1.2.0"
    },
    "anchor_type": {
      "enum": [
        "NEXT_STAGE_ANCHOR",
        "REPAIR_ANCHOR"
      ]
    },
    "boundary_ref": {
      "additionalProperties": false,
      "properties": {
        "boundary_id": {
          "minLength": 1,
          "type": "string"
        },
        "boundary_schema": {
          "const": "ev4-stage-boundary-record@1.0.0"
        },
        "boundary_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "boundary_id",
        "boundary_schema",
        "boundary_sha256"
      ],
      "type": "object"
    },
    "handoff_state": {
      "additionalProperties": false,
      "properties": {
        "audit_flags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "blocking_items": {
          "items": {
            "type": "object"
          },
          "type": "array"
        },
        "confidence_delta": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "critical_unknowns": {
          "items": {
            "type": "object"
          },
          "type": "array"
        },
        "gate_results": {
          "type": "string"
        },
        "partial_rerun_state": {
          "additionalProperties": false,
          "properties": {
            "downstream_payloads_dependent_on_this_stage": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "earliest_safe_rerun_stage": {
              "enum": [
                "/decompose",
                "/architectures",
                "/score-evidence",
                "/score-audit"
              ]
            },
            "invalidation_triggers": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "reusable_until": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "reusable_until",
            "invalidation_triggers",
            "earliest_safe_rerun_stage",
            "downstream_payloads_dependent_on_this_stage"
          ],
          "type": "object"
        },
        "required_user_confirmations": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "stage_boundary": {
          "additionalProperties": false,
          "properties": {
            "allowed_work": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "forbidden_work": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "stop_conditions": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "required": [
            "allowed_work",
            "forbidden_work",
            "stop_conditions"
          ],
          "type": "object"
        }
      },
      "required": [
        "critical_unknowns",
        "blocking_items",
        "confidence_delta",
        "gate_results",
        "audit_flags",
        "required_user_confirmations",
        "partial_rerun_state",
        "stage_boundary"
      ],
      "type": "object"
    },
    "repair_target_stage": {
      "type": [
        "string",
        "null"
      ]
    },
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "source_stage": {
      "enum": [
        "/decompose",
        "/architectures",
        "/score-evidence",
        "/score-audit"
      ]
    },
    "target_stage": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "anchor_schema",
    "anchor_id",
    "run_id",
    "anchor_type",
    "source_stage",
    "target_stage",
    "repair_target_stage",
    "boundary_ref",
    "handoff_state"
  ],
  "type": "object"
}
