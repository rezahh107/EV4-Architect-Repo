{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ev4-architect-conversational-stage-output-base@1.0.0",
  "title": "EV4 Architect Conversational Stage Output Base v1",
  "description": "Structural precheck for model-authored Architect Stage Output. It is not continuation authority and intentionally leaves Stage-specific semantics to the Pipeline Manifest and official Runtime.",
  "type": "object",
  "required": [
    "run_id",
    "stage_id",
    "stage_version",
    "check_evidence",
    "unknown_introductions",
    "unknown_resolutions",
    "blockers"
  ],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "stage_id": {"type": "string", "pattern": "^/[a-z0-9-]+$"},
    "stage_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "check_evidence": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/check_record"}
    },
    "unknown_introductions": {
      "type": "array",
      "items": {"$ref": "#/$defs/unknown_introduction"}
    },
    "unknown_resolutions": {
      "type": "array",
      "items": {"$ref": "#/$defs/unknown_resolution"}
    },
    "blockers": {
      "type": "array",
      "items": {"$ref": "#/$defs/blocker"}
    }
  },
  "additionalProperties": true,
  "propertyNames": {
    "not": {"$ref": "#/$defs/caller_authority_field"}
  },
  "$defs": {
    "caller_authority_field": {
      "enum": [
        "stage_result_schema",
        "stage_status",
        "blocking_issues",
        "carried_unknowns",
        "quality_checks",
        "next_stage",
        "decision_state",
        "runtime_context",
        "project_gate_export",
        "evaluation_mode",
        "evaluated_stage_output_digest",
        "status",
        "checks",
        "canonical_payload_valid",
        "legacy_export_substituted",
        "build_tree_digest",
        "implementation_digest",
        "implementation_tree_digest",
        "continuation_authorized",
        "official_pass",
        "official_digest"
      ]
    },
    "check_record": {
      "type": "object",
      "required": ["result", "reason"],
      "properties": {
        "result": {"enum": ["pass", "fail", "not_applicable", "unknown"]},
        "reason": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "unknown_introduction": {
      "type": "object",
      "required": ["unknown_id", "statement", "downstream_critical"],
      "properties": {
        "unknown_id": {"type": "string", "minLength": 1},
        "statement": {"type": "string", "minLength": 1},
        "downstream_critical": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "unknown_resolution": {
      "type": "object",
      "required": ["unknown_id", "resolution_type", "note"],
      "properties": {
        "unknown_id": {"type": "string", "minLength": 1},
        "resolution_type": {"enum": ["user_confirmation", "authoritative_source", "validated_artifact", "not_applicable"]},
        "note": {"type": "string", "minLength": 1},
        "evidence_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "blocker": {
      "type": "object",
      "required": ["issue_id", "reason"],
      "properties": {
        "issue_id": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "repair_stage": {
          "anyOf": [
            {"type": "string", "pattern": "^/[a-z0-9-]+$"},
            {"type": "null"}
          ]
        },
        "kind": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    }
  }
}
