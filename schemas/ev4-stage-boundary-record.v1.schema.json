{
  "$id": "ev4-stage-boundary-record@1.0.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "transition": {
            "const": "next_stage"
          }
        },
        "required": [
          "transition"
        ]
      },
      "then": {
        "properties": {
          "authorization": {
            "properties": {
              "next_stage_authorized": {
                "const": true
              }
            }
          },
          "receipt": {
            "properties": {
              "status": {
                "const": "valid"
              }
            }
          },
          "repair_target_stage": {
            "type": "null"
          },
          "target_stage": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transition": {
            "const": "repair"
          }
        },
        "required": [
          "transition"
        ]
      },
      "then": {
        "properties": {
          "authorization": {
            "properties": {
              "next_stage_authorized": {
                "const": false
              }
            }
          },
          "repair_target_stage": {
            "type": "string"
          },
          "target_stage": {
            "type": "null"
          }
        }
      }
    }
  ],
  "properties": {
    "artifact": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "minLength": 1,
          "type": "string"
        },
        "artifact_schema": {
          "const": "ev4-architect-pipeline-stage-artifact@1.1.0"
        },
        "artifact_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "artifact_schema",
        "artifact_sha256"
      ],
      "type": "object"
    },
    "authorization": {
      "additionalProperties": false,
      "properties": {
        "authorization_reason": {
          "minLength": 1,
          "type": "string"
        },
        "next_stage_authorized": {
          "type": "boolean"
        }
      },
      "required": [
        "next_stage_authorized",
        "authorization_reason"
      ],
      "type": "object"
    },
    "boundary_id": {
      "minLength": 1,
      "type": "string"
    },
    "boundary_schema": {
      "const": "ev4-stage-boundary-record@1.0.0"
    },
    "receipt": {
      "additionalProperties": false,
      "properties": {
        "receipt_id": {
          "minLength": 1,
          "type": "string"
        },
        "receipt_schema": {
          "const": "ev4-architect-stage-validation-receipt@1.1.0"
        },
        "receipt_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "status": {
          "enum": [
            "valid",
            "invalid",
            "insufficient_evidence"
          ]
        },
        "validator_id": {
          "const": "architect-pipeline-stage-boundary-validator"
        },
        "validator_version": {
          "const": "1.1.0"
        }
      },
      "required": [
        "receipt_id",
        "receipt_schema",
        "receipt_sha256",
        "validator_id",
        "validator_version",
        "status"
      ],
      "type": "object"
    },
    "repair_target_stage": {
      "type": [
        "string",
        "null"
      ]
    },
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "source_stage": {
      "enum": [
        "/decompose",
        "/architectures",
        "/score-evidence",
        "/score-audit"
      ]
    },
    "target_stage": {
      "type": [
        "string",
        "null"
      ]
    },
    "transition": {
      "enum": [
        "next_stage",
        "repair"
      ]
    }
  },
  "required": [
    "boundary_schema",
    "boundary_id",
    "run_id",
    "source_stage",
    "target_stage",
    "repair_target_stage",
    "transition",
    "artifact",
    "receipt",
    "authorization"
  ],
  "type": "object"
}
